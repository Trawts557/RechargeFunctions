<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RechargeFunctions.Mobile.Views.HistorialRecargasPage"
             Title="Historial de Recargas">

    <VerticalStackLayout Padding="20" Spacing="12">

        <SearchBar x:Name="BuscarRecargaSearchBar"
                   Placeholder="Buscar por cliente o tarjeta"
                   TextChanged="OnBuscarRecargaTextChanged" />

        <CollectionView x:Name="RecargasCollectionView"
                        SelectionMode="Single"
                        SelectionChanged="OnRecargaSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12" Margin="0,6">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding ClienteNombre}"
                                   FontAttributes="Bold"
                                   FontSize="16" />

                            <Label Text="{Binding TarjetaNombre}" />

                            <Label Text="{Binding MontoRecarga, StringFormat='Monto: {0:F2}'}" />

                            <Label Text="{Binding FechaRecarga, StringFormat='Fecha: {0:dd/MM/yyyy HH:mm}'}" />

                            <Label Text="{Binding EstadoTexto}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>