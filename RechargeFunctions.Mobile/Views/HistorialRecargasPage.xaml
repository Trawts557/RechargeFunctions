<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RechargeFunctions.Mobile.Views.HistorialRecargasPage"
             Title="Historial de Recargas"
             BackgroundColor="{AppThemeBinding Light=#F7F8FA, Dark=#111315}">

    <Grid Padding="20"
          RowDefinitions="Auto,*"
          RowSpacing="12">

        <SearchBar Grid.Row="0"
                   x:Name="BuscarRecargaSearchBar"
                   Placeholder="Buscar por cliente o tarjeta"
                   TextChanged="OnBuscarRecargaTextChanged" />

        <CollectionView Grid.Row="1"
                        x:Name="RecargasCollectionView"
                        SelectionMode="Single"
                        SelectionChanged="OnRecargaSelectionChanged"
                        EmptyView="No hay recargas registradas."
                        VerticalScrollBarVisibility="Always">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical"
                                   ItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#2D333B}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1D21}"
                            StrokeShape="RoundRectangle 16">

                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding ClienteNombre}"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=White}" />

                            <Label Text="{Binding TarjetaNombre}"
                                   TextColor="{AppThemeBinding Light=#4B5563, Dark=#C7CDD4}" />

                            <Label Text="{Binding MontoRecarga, StringFormat='Monto: {0:F2}'}"
                                   TextColor="{AppThemeBinding Light=#4B5563, Dark=#C7CDD4}" />

                            <Label Text="{Binding FechaRecarga, StringFormat='Fecha: {0:dd/MM/yyyy HH:mm}'}"
                                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />

                            <Label Text="{Binding EstadoTexto}"
                                   TextColor="{AppThemeBinding Light=#4338CA, Dark=#C7D2FE}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>