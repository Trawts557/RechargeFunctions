<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RechargeFunctions.Mobile.Views.TarjetasPage"
             Title="Tarjetas">

    <VerticalStackLayout Padding="20" Spacing="12">

        <SearchBar x:Name="BuscarTarjetaSearchBar"
                   Placeholder="Buscar por nombre o últimos dígitos"
                   TextChanged="OnBuscarTarjetaTextChanged" />

        <CollectionView x:Name="TarjetasCollectionView"
                        SelectionMode="Single"
                        SelectionChanged="OnTarjetaSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12" Margin="0,6">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Nombre}"
                                   FontAttributes="Bold"
                                   FontSize="16" />

                            <Label Text="{Binding UltimosDigitos, StringFormat='Últimos dígitos: {0}'}" />

                            <Label Text="{Binding EstadoTexto}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>