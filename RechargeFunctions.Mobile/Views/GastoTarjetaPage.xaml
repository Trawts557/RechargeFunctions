<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RechargeFunctions.Mobile.Views.GastoTarjetaPage"
             Title="Gasto y Ganancias por Tarjeta"
             BackgroundColor="{AppThemeBinding Light=#F7F8FA, Dark=#111315}">

    <Grid Padding="20"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="12">

        <Border Grid.Row="0"
                Padding="15"
                StrokeThickness="1"
                Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#2D333B}"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1D21}"
                StrokeShape="RoundRectangle 16">

            <VerticalStackLayout Spacing="10">

                <Label Text="Filtrar por período"
                       FontAttributes="Bold"
                       FontSize="18"
                       TextColor="{AppThemeBinding Light=#111827, Dark=White}" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">

                    <VerticalStackLayout Grid.Column="0"
                                         Spacing="4">
                        <Label Text="Mes"
                               TextColor="{AppThemeBinding Light=#4B5563, Dark=#C7CDD4}" />

                        <Picker x:Name="MesPicker"
                                Title="Seleccione mes"
                                SelectedIndexChanged="OnFiltroChanged" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="4">
                        <Label Text="Año"
                               TextColor="{AppThemeBinding Light=#4B5563, Dark=#C7CDD4}" />

                        <Picker x:Name="AnioPicker"
                                Title="Seleccione año"
                                SelectedIndexChanged="OnFiltroChanged" />
                    </VerticalStackLayout>

                </Grid>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1"
                Padding="15"
                StrokeThickness="1"
                Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#2D333B}"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1D21}"
                StrokeShape="RoundRectangle 16">

            <VerticalStackLayout Spacing="6">
                <Label Text="Resumen General"
                       FontAttributes="Bold"
                       FontSize="18"
                       TextColor="{AppThemeBinding Light=#111827, Dark=White}" />

                <Label x:Name="TotalGastadoGeneralLabel"
                       Text="Total gastado: 0.00"
                       TextColor="{AppThemeBinding Light=#4B5563, Dark=#C7CDD4}" />

                <Label x:Name="TotalGananciasGeneralLabel"
                       Text="Ganancias: 0.00"
                       TextColor="{AppThemeBinding Light=#4B5563, Dark=#C7CDD4}" />

                <Label x:Name="TotalRecargasGeneralLabel"
                       Text="Recargas: 0"
                       TextColor="{AppThemeBinding Light=#4B5563, Dark=#C7CDD4}" />
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="2"
                        x:Name="ResumenTarjetasCollectionView"
                        SelectionMode="None"
                        EmptyView="No hay datos para mostrar."
                        VerticalScrollBarVisibility="Always">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical"
                                   ItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#2D333B}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1D21}"
                            StrokeShape="RoundRectangle 16">

                        <VerticalStackLayout Spacing="4">

                            <Label Text="{Binding TarjetaNombre}"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=White}" />

                            <Label Text="{Binding TotalGastado, StringFormat='Total gastado: {0:F2}'}"
                                   TextColor="{AppThemeBinding Light=#4B5563, Dark=#C7CDD4}" />

                            <Label Text="{Binding Ganancias, StringFormat='Ganancias: {0:F2}'}"
                                   TextColor="{AppThemeBinding Light=#4B5563, Dark=#C7CDD4}" />

                            <Label Text="{Binding CantidadRecargas, StringFormat='Cantidad de recargas: {0}'}"
                                   TextColor="{AppThemeBinding Light=#4B5563, Dark=#C7CDD4}" />

                            <Label Text="{Binding CantidadPagadas, StringFormat='Pagadas: {0}'}"
                                   TextColor="{AppThemeBinding Light=#4B5563, Dark=#C7CDD4}" />

                            <Label Text="{Binding CantidadPendientes, StringFormat='Pendientes: {0}'}"
                                   TextColor="{AppThemeBinding Light=#4B5563, Dark=#C7CDD4}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>