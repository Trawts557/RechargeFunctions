<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RechargeFunctions.Mobile.Views.AgregarClientePage"
             Title="Agregar Cliente">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Nombre" FontAttributes="Bold" />
            <Entry x:Name="NombreEntry"
                   Placeholder="Ingrese el nombre" />

            <Label Text="Apellido" FontAttributes="Bold" />
            <Entry x:Name="ApellidoEntry"
                   Placeholder="Ingrese el apellido" />

            <Label Text="Apodo" FontAttributes="Bold" />
            <Entry x:Name="ApodoEntry"
                   Placeholder="Ingrese el apodo" />

            <Label Text="NIC" FontAttributes="Bold" />
            <Entry x:Name="NicEntry"
                   Placeholder="Ingrese el NIC"
                   Keyboard="Numeric" />

            <Label Text="Número de teléfono (opcional)" FontAttributes="Bold" />
            <Entry x:Name="NumeroTelefonoEntry"
                   Placeholder="Ejemplo: 8091234567"
                   Keyboard="Telephone" />

            <Button Text="Guardar Cliente"
                    Clicked="OnGuardarClienteClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>