<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RechargeFunctions.Mobile.Views.PagosPendientesPage"
             Title="Deudas Pendientes">

    <Grid Padding="20">
        <CollectionView x:Name="RecargasCollectionView"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12" Margin="0,6">
                        <VerticalStackLayout Spacing="6">

                            <Label Text="{Binding ClienteNombre}"
                                   FontAttributes="Bold"
                                   FontSize="16" />

                            <Label Text="{Binding TarjetaNombre}" />

                            <Label Text="{Binding MontoRecarga, StringFormat='Monto: {0:F2}'}" />

                            <Label Text="{Binding FechaRecarga, StringFormat='Fecha: {0:dd/MM/yyyy HH:mm}'}" />

                            <Label Text="Pendiente" TextColor="Red" />

                            <Button Text="Marcar como pagada"
                                    Clicked="OnMarcarPagadaClicked"
                                    CommandParameter="{Binding Id}" />

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>